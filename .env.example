# Doc-Hub configuration — copy to .env and fill in.
# This file is the contract; do NOT commit a populated .env.

# ─── Origins ─────────────────────────────────────────────────────────────────
# App origin: SPA, JSON API, WOPI host endpoints.
DOCHUB_APP_ORIGIN=https://drive.example.org
# User-content origin: serves /raw/{token} only. MUST differ from app origin in prod.
DOCHUB_USERCONTENT_ORIGIN=https://usercontent-drive.example.org

# ─── Server ──────────────────────────────────────────────────────────────────
DOCHUB_BIND=0.0.0.0:8080
DOCHUB_BODY_LIMIT_MB=100
DOCHUB_PROD=true
RUST_LOG=info,dochub=debug

# ─── Secrets (32-byte base64; boot refuses anything shorter in prod) ─────────
DOCHUB_SESSION_SECRET=
DOCHUB_WOPI_HMAC_SECRET=
DOCHUB_SIGNED_URL_HMAC_SECRET=

# Master key-encryption-key: base64-encoded 32 bytes. Wraps every per-workspace
# DEK; boot REFUSES to start without it (at-rest encryption is not optional).
# Generate with: head -c 32 /dev/urandom | base64
DOCHUB_MASTER_KEY=

# Optional rotation target (base64-encoded 32 bytes). Set only while rotating
# the master KEK: with both keys present, `dochub rotate-kek` re-wraps every
# per-workspace DEK from DOCHUB_MASTER_KEY to this one WITHOUT rewriting any
# document blob. On a clean run, promote this value to DOCHUB_MASTER_KEY and
# unset it. Leave empty in steady state.
DOCHUB_MASTER_KEY_NEXT=

# ─── Admin (single-tenant v0) ────────────────────────────────────────────────
DOCHUB_ADMIN_USER=admin
# Generate with: argon2 yoursalt -id -t 2 -m 14 -p 1 -e
DOCHUB_ADMIN_PASSWORD_HASH=

# ─── Storage backend (one of: fs | memory | s3 | minio) ──────────────────────
DOCHUB_BACKEND=fs

# fs adapter
DOCHUB_FS_ROOT=/var/lib/drive/data

# s3 / minio adapter (set DOCHUB_S3_ENDPOINT for MinIO)
DOCHUB_S3_BUCKET=
DOCHUB_S3_REGION=us-east-1
DOCHUB_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Database (sqlite default; postgres for production) ──────────────────────
DOCHUB_DB_URL=sqlite:///var/lib/drive/drive.db
# DOCHUB_DB_URL=postgres://drive:drive@localhost:5432/drive

# ─── Antivirus (optional; ClamAV via Unix socket) ────────────────────────────
# DOCHUB_ANTIVIRUS=clamd
# DOCHUB_CLAMD_SOCKET=/var/run/clamav/clamd.ctl

# ─── Real-time co-editing (optional; sibling `collab` Hocuspocus/Yjs server) ──
# When set, Doc-Hub brokers per-document collab rooms and seeds them from the
# encrypted head version. When unset, editing falls back to single-user (P2.1).
# Point the collab server's CASUAL_JWT_SECRET at DOCHUB_WOPI_HMAC_SECRET so it
# can validate the editor access tokens Doc-Hub mints.
#
# FOOTGUN — DOCHUB_COLLAB_URL is BROWSER-facing, not a URL Doc-Hub dials. The
# backend only reflects it into the room ws_url handed to the browser (see
# crates/dochub-http/src/collab.rs `collab_ws_url`), so it must be reachable
# FROM THE BROWSER — the host-published gateway, never compose-internal DNS.
# In the canonical docker-compose.yml this is the published gateway on :8082.
# DOCHUB_COLLAB_URL=https://collab.example.org

# SPA build-arg — baked into the bundle for the SDK direct-mount collab path
# (wired in a later phase). Also browser-facing ⇒ the host-published ws URL of
# the gateway. Consumed at `docker build`, not at runtime. Compose default:
# ws://localhost:8082 (matches DOCHUB_COLLAB_URL's host-published gateway).
# VITE_DRIVE_COLLAB_BACKEND_URL=ws://localhost:8082

# ─── Recipient share page footer (operator may disable) ──────────────────────
DOCHUB_RECIPIENT_FOOTER=true
