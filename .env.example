# Doc-Hub configuration — copy to .env and fill in.
# This file is the contract; do NOT commit a populated .env.

# ─── Origins ─────────────────────────────────────────────────────────────────
# App origin: SPA, JSON API, WOPI host endpoints.
DOCHUB_APP_ORIGIN=https://hub.example.org
# User-content origin: serves /raw/{token} only. MUST differ from app origin in prod.
DOCHUB_USERCONTENT_ORIGIN=https://usercontent.example.org

# ─── Server ──────────────────────────────────────────────────────────────────
DOCHUB_BIND=0.0.0.0:8080
DOCHUB_BODY_LIMIT_MB=100
DOCHUB_PROD=true
# Signed download-URL lifetime in seconds (min 30). Default 300 (5 min).
DOCHUB_SIGNED_URL_TTL_SECS=300
# Access-log format: json (default in prod) | text (default otherwise).
DOCHUB_LOG_FORMAT=json
RUST_LOG=info,dochub=debug

# ─── Secrets (32-byte base64; boot refuses anything shorter in prod) ─────────
DOCHUB_SESSION_SECRET=
DOCHUB_WOPI_HMAC_SECRET=
DOCHUB_SIGNED_URL_HMAC_SECRET=

# Master key-encryption-key: base64-encoded 32 bytes. Wraps every per-workspace
# DEK; boot REFUSES to start without it (at-rest encryption is not optional).
# Generate with: head -c 32 /dev/urandom | base64
DOCHUB_MASTER_KEY=

# Optional rotation target (base64-encoded 32 bytes). Set only while rotating
# the master KEK: with both keys present, `dochub rotate-kek` re-wraps every
# per-workspace DEK from DOCHUB_MASTER_KEY to this one WITHOUT rewriting any
# document blob. On a clean run, promote this value to DOCHUB_MASTER_KEY and
# unset it. Leave empty in steady state.
DOCHUB_MASTER_KEY_NEXT=

# ─── Admin (single-tenant v0) ────────────────────────────────────────────────
DOCHUB_ADMIN_USER=admin
# Generate with: argon2 yoursalt -id -t 2 -m 14 -p 1 -e
DOCHUB_ADMIN_PASSWORD_HASH=
# Hide the password sign-in form server-side once OIDC is the only sanctioned
# path (the /api/auth/sign-in route then 404s). Default true.
DOCHUB_ALLOW_PASSWORD_AUTH=true

# ─── Storage backend (one of: fs | memory | s3 | minio) ──────────────────────
DOCHUB_BACKEND=fs

# fs adapter
DOCHUB_FS_ROOT=/var/lib/dochub/data

# s3 / minio adapter (set DOCHUB_S3_ENDPOINT for MinIO)
DOCHUB_S3_BUCKET=
DOCHUB_S3_REGION=us-east-1
DOCHUB_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: seals bring-your-own storage credentials at rest (hex 32 bytes).
# Without it, saving a BYO storage config is refused (503). Generate with:
# openssl rand -hex 32
# DOCHUB_STORAGE_SECRET_KEY=

# ─── Database (sqlite default; postgres for production) ──────────────────────
DOCHUB_DB_URL=sqlite:///var/lib/dochub/dochub.db
# DOCHUB_DB_URL=postgres://dochub:dochub@localhost:5432/dochub

# ─── Upload safety ───────────────────────────────────────────────────────────
# There is no built-in antivirus scanner. Uploads are constrained by the
# documents-only ingest gate instead: every file is checked against the MIME
# allowlist by BOTH extension and magic-byte sniff, and anything else is
# rejected (crates/dochub-core/src/ingest.rs). Run a scanner at your proxy or
# storage layer if you need one.

# ─── OIDC single sign-on (optional) ──────────────────────────────────────────
# Setting DOCHUB_OIDC_ISSUER turns on OIDC (Authorization Code + PKCE); the
# ISSUER/CLIENT_ID/CLIENT_SECRET/REDIRECT_URL quartet then go together. Register
# the redirect URL below with your IdP.
# DOCHUB_OIDC_ISSUER=https://idp.example.org
# DOCHUB_OIDC_CLIENT_ID=
# DOCHUB_OIDC_CLIENT_SECRET=
# DOCHUB_OIDC_REDIRECT_URL=https://hub.example.org/api/auth/oidc/callback
# Space-separated; default "openid email profile".
# DOCHUB_OIDC_SCOPES=openid email profile
# Members of this IdP group (per the `groups` claim) become admins on sign-in.
# DOCHUB_OIDC_ADMIN_GROUP=
# Auto-provision a user row on first sign-in by an unknown subject (else 403).
# Default true.
# DOCHUB_OIDC_AUTO_CREATE_USERS=true
# Shown on the sign-in card next to the IdP button.
# DOCHUB_OIDC_PROVIDER_LABEL=your identity provider
# Stable id for the users.oidc_provider_id column; defaults to a hash of the
# issuer. Set explicitly if you may rotate issuers.
# DOCHUB_OIDC_PROVIDER_ID=

# ─── AI layer (optional; semantic search, summaries, cross-doc Q&A) ──────────
# Setting DOCHUB_AI_PROVIDER turns it on. Providers: anthropic | openai. For a
# local, air-gapped model point BASE_URL at an OpenAI-compatible server (e.g.
# Ollama at http://localhost:11434/v1).
# DOCHUB_AI_PROVIDER=anthropic
# API key; falls back to ANTHROPIC_API_KEY / OPENAI_API_KEY for the provider.
# DOCHUB_AI_API_KEY=
# Override the provider's default model.
# DOCHUB_AI_MODEL=
# Override the provider's default API base URL.
# DOCHUB_AI_BASE_URL=

# ─── Real-time co-editing (optional; sibling `collab` Hocuspocus/Yjs server) ──
# When set, Doc-Hub brokers per-document collab rooms and seeds them from the
# encrypted head version. When unset, editing falls back to single-user (P2.1).
# Point the collab server's CASUAL_JWT_SECRET at DOCHUB_WOPI_HMAC_SECRET so it
# can validate the editor access tokens Doc-Hub mints.
#
# FOOTGUN — DOCHUB_COLLAB_URL is BROWSER-facing, not a URL Doc-Hub dials. The
# backend only reflects it into the room ws_url handed to the browser (see
# crates/dochub-http/src/collab.rs `collab_ws_url`), so it must be reachable
# FROM THE BROWSER — the host-published gateway, never compose-internal DNS.
# In the canonical docker-compose.yml this is the published gateway on :8082.
# DOCHUB_COLLAB_URL=https://collab.example.org

# SPA build-arg — baked into the bundle for the SDK direct-mount collab path
# (wired in a later phase). Also browser-facing ⇒ the host-published ws URL of
# the gateway. Consumed at `docker build`, not at runtime. Compose default:
# ws://localhost:8082 (matches DOCHUB_COLLAB_URL's host-published gateway).
# VITE_DRIVE_COLLAB_BACKEND_URL=ws://localhost:8082

# ─── Recipient share page footer (operator may disable) ──────────────────────
DOCHUB_RECIPIENT_FOOTER=true
