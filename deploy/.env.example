# ═══════════════════════════════════════════════════════════════════════════
# Doc-Hub deploy samples — environment contract
# ═══════════════════════════════════════════════════════════════════════════
# Copy to deploy/.env and fill in. The compose samples read it via
# `--env-file ../.env`. NEVER commit a populated .env — placeholders only here.
#
# Which sample needs what (details per-var below):
#   coediting.yml        works with ALL dev defaults (override secrets for real use)
#   single-user.yml      same, minus the collab vars
#   postgres.yml         same as coediting + DOCHUB_DB_URL (has a working default)
#   external-storage.yml REQUIRES DOCHUB_S3_BUCKET + AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
#   production.yml       REQUIRES everything below (no fallbacks; DOCHUB_PROD=true)
# ═══════════════════════════════════════════════════════════════════════════

# ─── Origins (production.yml requires both; must be DISTINCT hostnames) ───────
# The two-origin model is non-negotiable in prod: app serves SPA/API, the
# user-content origin serves share links only. Prod boot refuses if equal.
DOCHUB_APP_ORIGIN=https://drive.example.org
DOCHUB_USERCONTENT_ORIGIN=https://usercontent.example.org

# ─── Server ──────────────────────────────────────────────────────────────────
DOCHUB_BODY_LIMIT_MB=100
RUST_LOG=info,dochub=debug

# ─── At-rest encryption KEK (ALL samples — boot refuses to start without it) ──
# base64-encoded 32 bytes. Generate with:  head -c 32 /dev/urandom | base64
# The dev-defaulted samples embed a throwaway key; override it here for anything
# real. production.yml has NO default — you MUST set it.
DOCHUB_MASTER_KEY=

# ─── Secrets (ALL samples; >=32 bytes each; prod also rejects the dev defaults)─
# Generate each with:  head -c 32 /dev/urandom | base64
# DOCHUB_WOPI_HMAC_SECRET is ALSO the collab gateway's CASUAL_JWT_SECRET — the
# samples wire both from this single variable so they can never drift.
DOCHUB_SESSION_SECRET=
DOCHUB_WOPI_HMAC_SECRET=
DOCHUB_SIGNED_URL_HMAC_SECRET=

# ─── Admin (single-tenant) ───────────────────────────────────────────────────
# Generate the hash with:  argon2 <yoursalt> -id -t 2 -m 14 -p 1 -e
DOCHUB_ADMIN_USER=admin
DOCHUB_ADMIN_PASSWORD_HASH=

# ─── Real-time co-editing (coediting / postgres / external-storage / prod) ────
# THE DUAL-URL FOOTGUN: both of these are BROWSER-facing and point at the SAME
# gateway. DOCHUB_COLLAB_URL is NOT a URL the backend dials — dochub only
# reflects it into the room ws_url handed to the browser, so it must be
# browser-reachable (host-published :8082 locally, your public collab host in
# prod), NEVER compose-internal DNS like http://collab:8080.
#
# VITE_DRIVE_COLLAB_BACKEND_URL is a BUILD arg baked into the SPA bundle at
# `docker build`; rebuild the image when it changes. Also browser-facing.
#
# single-user.yml uses NEITHER (no collab service; editors run single-user).
DOCHUB_COLLAB_URL=http://localhost:8082
VITE_DRIVE_COLLAB_BACKEND_URL=ws://localhost:8082

# ─── Database ────────────────────────────────────────────────────────────────
# coediting.yml / single-user.yml / external-storage.yml default to file SQLite
# inside the container. postgres.yml defaults to its in-compose postgres.
# production.yml REQUIRES an external Postgres URL. sqlx pool is backend-erased;
# migrations are portable across SQLite and Postgres.
#   SQLite:    sqlite:///data/drive.db
#   Postgres:  postgres://dochub:dochub@postgres:5432/dochub   (in-compose)
#   Postgres:  postgres://user:pass@db.example.org:5432/dochub (external/prod)
DOCHUB_DB_URL=postgres://dochub:dochub@postgres:5432/dochub

# ─── External S3-compatible storage (external-storage.yml / production.yml) ───
# Not needed by the MinIO-bundled samples. For AWS S3 you may leave the endpoint
# empty to use the default; set it for R2 / B2 / Wasabi / self-hosted MinIO.
#   R2:  https://<account>.r2.cloudflarestorage.com   (region: auto)
#   B2:  https://s3.<region>.backblazeb2.com
DOCHUB_S3_BUCKET=my-dochub-bucket
DOCHUB_S3_REGION=us-east-1
DOCHUB_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Production image (production.yml) ────────────────────────────────────────
# Optional override for the built/pulled image tag used by production.yml.
# DOCHUB_IMAGE=registry.example.org/dochub:1.0.0
