---
/**
 * Landing — /
 * Spec: docs/ux/14-marketing-surface.md.
 * SEO: SoftwareApplication JSON-LD; single H1 lives in Hero.
 */
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ScreenshotShowcase from "../components/ScreenshotShowcase.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Compare from "../components/Compare.astro";
import FinalCta from "../components/FinalCta.astro";

const description =
  "Doc-Hub is an open-source, self-hosted document hub — an encrypted, tamper-evident registry that versions every .docx, .xlsx and .pdf forever, edits them natively in the browser, and searches inside them. Rust + React, single binary, no tracking.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Doc-Hub",
  description,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, Docker, Linux, macOS",
  url: "https://casualoffice.org/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  license: "https://opensource.org/license/mit",
  isAccessibleForFree: true,
  softwareRequirements: "Modern browser, plus a server for self-hosting",
};
---

<Base
  title="Self-hosted, encrypted document hub with permanent history"
  description={description}
  jsonLd={jsonLd}
>
  <Hero />
  <ScreenshotShowcase />
  <FeatureGrid />
  <HowItWorks />
  <Compare />
  <FinalCta />
</Base>
