---
/**
 * Screenshot showcase — tabbed device frame. Sources are captured by
 * web/tests/e2e/marketing-screenshots.mjs against the demo SPA build, so
 * the assets stay in lock-step with the actual surface.
 */
const shots = [
  {
    id: "files",
    label: "Documents",
    src: "/screenshots/files-list.png",
    alt: "Doc-Hub — document list showing folders and documents: an .xlsx, a .docx, and a PDF",
  },
  {
    id: "history",
    label: "History",
    src: "/screenshots/version-history.png",
    alt: "Version history — the hash-chained ledger of immutable document versions, verifiable end to end",
  },
  {
    id: "cmdk",
    label: "Cmd-K",
    src: "/screenshots/command-palette.png",
    alt: "Cmd-K command palette — search documents and navigate from anywhere",
  },
  {
    id: "share",
    label: "Sharing",
    src: "/screenshots/share-dialog.png",
    alt: "Share dialog — password-protected, expiring links for a document",
  },
  {
    id: "admin",
    label: "Admin",
    src: "/screenshots/admin-users.png",
    alt: "Admin → Users surface — users table with per-user quota controls",
  },
  {
    id: "storage",
    label: "Storage",
    src: "/screenshots/settings-storage.png",
    alt: "Settings → Storage — backend readout, usage, and the bring-your-own bucket card",
  },
];
---

<section class="showcase cv-auto" aria-label="Preview of today's Doc-Hub UI">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Preview</p>
      <h2 class="section-title">A look at today's UI.</h2>
      <p class="section-lede">
        These shots are the current pre-redesign interface. The redesigned
        Doc-Hub web app — history timeline, encrypted document view, native
        editors — ships alongside the server in Phase 2 (see the
        <a href="/roadmap">roadmap</a>). Until then, the demo reflects the
        earlier UI.
      </p>
    </header>

    <div class="showcase-frame">
      <div class="showcase-tabs" role="tablist">
        {
          shots.map((s, i) => (
            <button
              type="button"
              role="tab"
              class="showcase-tab"
              data-target={s.id}
              aria-selected={i === 0 ? "true" : "false"}
              tabindex={i === 0 ? 0 : -1}
            >
              {s.label}
            </button>
          ))
        }
      </div>

      <div class="showcase-stage">
        {
          shots.map((s, i) => {
            // AVIF + WebP variants are generated by
            // scripts/optimize-screenshots.mjs alongside each PNG.
            // Two sizes per format: full-resolution (1600w) for
            // desktop, and a 800w build for mobile under
            // (max-width: 768px). Source order matters — the browser
            // picks the FIRST matching `<source>`, so small variants
            // come first.
            const base = s.src.replace(/\.png$/i, "");
            const MOBILE_MEDIA = "(max-width: 768px)";
            return (
              <figure class="showcase-shot" data-shot={s.id} hidden={i !== 0}>
                <picture>
                  <source
                    type="image/avif"
                    media={MOBILE_MEDIA}
                    srcset={`${base}@800w.avif`}
                  />
                  <source
                    type="image/webp"
                    media={MOBILE_MEDIA}
                    srcset={`${base}@800w.webp`}
                  />
                  <source type="image/avif" srcset={`${base}.avif`} />
                  <source type="image/webp" srcset={`${base}.webp`} />
                  <img
                    src={s.src}
                    alt={s.alt}
                    width="1600"
                    height="1000"
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding={i === 0 ? "sync" : "async"}
                    fetchpriority={i === 0 ? "high" : "auto"}
                    onerror="this.parentNode.parentNode.classList.add('showcase-fallback')"
                  />
                </picture>
                <div class="showcase-fallback-msg" aria-hidden="true">
                  <span>{s.label} screenshot · captured in the demo</span>
                </div>
              </figure>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".showcase-tab");
  const shots = document.querySelectorAll<HTMLElement>(".showcase-shot");

  function activate(id: string) {
    tabs.forEach((t) => {
      const active = t.dataset.target === id;
      t.setAttribute("aria-selected", active ? "true" : "false");
      t.tabIndex = active ? 0 : -1;
    });
    shots.forEach((s) => {
      s.hidden = s.dataset.shot !== id;
    });
  }

  tabs.forEach((t) => {
    t.addEventListener("click", () => activate(t.dataset.target!));
  });

  // Keyboard support — ←/→ cycles tabs.
  const tabList = Array.from(tabs);
  tabList.forEach((t, i) => {
    t.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") {
        const next = tabList[(i + 1) % tabList.length];
        next.focus();
        activate(next.dataset.target!);
      } else if (e.key === "ArrowLeft") {
        const prev = tabList[(i - 1 + tabList.length) % tabList.length];
        prev.focus();
        activate(prev.dataset.target!);
      }
    });
  });
</script>

<style>
  .section-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto var(--space-12);
  }

  .section-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink);
    background: var(--violet-100);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
  }

  .section-title {
    font-size: var(--text-3xl);
    letter-spacing: -0.025em;
    margin-bottom: var(--space-3);
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: var(--text-4xl);
    }
  }

  .section-lede {
    color: var(--muted);
    font-size: var(--text-md);
    line-height: 1.6;
  }

  .section-lede a {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 650;
  }

  .showcase {
    padding-block: var(--space-8) var(--space-16);
  }

  @media (min-width: 768px) {
    .showcase {
      padding-block: var(--space-10) var(--space-20);
    }
  }

  .showcase-frame {
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--card);
    overflow: hidden;
    box-shadow: var(--shadow-hover);
  }

  .showcase-tabs {
    display: flex;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--paper-2);
    border-bottom: var(--border-w) solid var(--border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .showcase-tabs::-webkit-scrollbar {
    display: none;
  }

  .showcase-tab {
    flex-shrink: 0;
    min-height: 38px;
    padding: 0 var(--space-4);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--card);
    font-size: var(--text-sm);
    font-weight: 650;
    color: var(--ink-soft);
    transition:
      background var(--dur) var(--ease),
      color var(--dur) var(--ease);
    user-select: none;
  }

  .showcase-tab:hover {
    background: var(--violet-100);
    color: var(--ink);
  }

  .showcase-tab[aria-selected="true"] {
    background: var(--violet-500);
    color: var(--on-violet);
  }

  .showcase-stage {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--bg-subtle);
  }

  .showcase-shot {
    margin: 0;
    position: absolute;
    inset: 0;
  }

  .showcase-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* Friendly fallback when a screenshot is missing during early dev. */
  .showcase-shot.showcase-fallback img {
    display: none;
  }

  .showcase-fallback-msg {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: var(--text-sm);
    background: repeating-linear-gradient(
      45deg,
      var(--bg-subtle),
      var(--bg-subtle) 12px,
      var(--paper-2) 12px,
      var(--paper-2) 24px
    );
  }

  .showcase-shot.showcase-fallback .showcase-fallback-msg {
    display: flex;
  }
</style>
