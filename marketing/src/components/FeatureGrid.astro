---
import FileText from "./icons/FileText.astro";
import Server from "./icons/Server.astro";
import Search from "./icons/Search.astro";
import Shield from "./icons/Shield.astro";
import Activity from "./icons/Activity.astro";
import EyeOff from "./icons/EyeOff.astro";

const features = [
  {
    icon: Activity,
    title: "History you can't rewrite",
    body: "Every save appends a new, hash-chained version. Nothing is overwritten, nothing is hard-deleted — alter a past byte and verification fails.",
  },
  {
    icon: Shield,
    title: "Encrypted at rest",
    body: "AES-256-GCM envelope encryption, per-workspace keys you control. A stolen disk or database dump is just ciphertext. The server holds keys by design, though — so Doc-Hub is not zero-knowledge end-to-end.",
  },
  {
    icon: FileText,
    title: "Edit natively, in place",
    body: "Click a .docx or .xlsx — it opens in the embedded Casual Docs or Sheet, with real-time co-editing. Every save lands as a version.",
  },
  {
    icon: Search,
    title: "Search inside documents",
    body: "Full-text search reads the content of every document, not just the filename. Ask which file mentions X — and find it.",
  },
  {
    icon: Server,
    title: "Self-host anywhere",
    body: "Filesystem, S3, MinIO, R2, or B2. One env var swaps the backend. SQLite on a $5 VPS, or Postgres at scale.",
  },
  {
    icon: EyeOff,
    title: "No tracking, ever",
    body: "Zero analytics. No fingerprinting. No newsletter pop-up. Your documents aren't a marketing funnel.",
  },
];
---

<section id="features" class="section cv-auto">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">The four promises</p>
      <h2 class="section-title">A registry, not a folder.</h2>
      <p class="section-lede">
        A place to keep the documents you can't afford to lose or leak — with
        a history you can prove and encryption you control. Documents only.
      </p>
    </header>

    <ul class="feature-grid" role="list">
      {
        features.map(({ icon: Icon, title, body }) => (
          <li class="feature">
            <span class="feature-icon">
              <Icon size={18} />
            </span>
            <h3 class="feature-title">{title}</h3>
            <p class="feature-body">{body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    max-width: 680px;
    margin: 0 auto var(--space-12);
  }

  .section-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink);
    background: var(--violet-100);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
  }

  .section-title {
    font-size: var(--text-3xl);
    letter-spacing: -0.025em;
    margin-bottom: var(--space-3);
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .section-title {
      font-size: var(--text-4xl);
    }
  }

  .section-lede {
    color: var(--muted);
    font-size: var(--text-md);
    line-height: 1.6;
  }

  .feature-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .feature-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .feature {
    padding: var(--space-6);
    background: var(--card);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition:
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .feature:hover {
    transform: var(--lift);
    box-shadow: var(--shadow-hover);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature:hover {
      transform: none;
    }
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--violet-100);
    color: var(--violet-500);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
  }

  .feature-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
    letter-spacing: -0.015em;
    font-weight: 650;
  }

  .feature-body {
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }
</style>
