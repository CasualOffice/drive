---
import ArrowRight from "./icons/ArrowRight.astro";
import Star from "./icons/Star.astro";
import GithubIcon from "./icons/Github.astro";
---

<section class="cta cv-auto">
  <div class="container">
    <div class="cta-card">
      <h2 class="cta-title">Take it for a spin.</h2>
      <p class="cta-body">
        The demo runs in your browser with a seeded admin account and a few
        versioned documents. Nothing you do leaves your tab. When you've seen
        enough, the install instructions are one click away.
      </p>
      <div class="cta-actions">
        <a href="/demo" class="btn btn-primary btn-lg">
          Open the demo
          <ArrowRight size={16} />
        </a>
        <a href="/docs/install" class="btn btn-secondary btn-lg">
          Install instructions
        </a>
        <a
          href="https://github.com/CasualOffice/drive"
          class="btn btn-secondary btn-lg"
          rel="noopener external"
          target="_blank"
        >
          <Star size={16} /> Star on GitHub
          <GithubIcon size={16} />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: var(--space-12) var(--space-16);
  }

  .cta-card {
    text-align: center;
    padding: var(--space-12) var(--space-6);
    background: var(--violet-500);
    color: var(--on-violet);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-hover);
  }

  @media (min-width: 768px) {
    .cta-card {
      padding: var(--space-16) var(--space-10);
    }
  }

  .cta-title {
    font-size: var(--text-3xl);
    letter-spacing: -0.025em;
    margin-bottom: var(--space-3);
    color: var(--on-violet);
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .cta-title {
      font-size: var(--text-4xl);
    }
  }

  .cta-body {
    color: var(--on-violet);
    max-width: 480px;
    margin: 0 auto var(--space-8);
    font-size: var(--text-md);
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: stretch;
    max-width: 360px;
    margin: 0 auto;
  }

  /* On the violet block, both CTAs read as solid paper buttons with the
     signature ink border + hard offset shadow. */
  .cta-actions :global(.btn) {
    background: var(--card);
    color: var(--ink);
  }

  .cta-actions :global(.btn:hover) {
    background: var(--paper-2);
    color: var(--ink);
  }

  @media (min-width: 640px) {
    .cta-actions {
      flex-direction: row;
      max-width: none;
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>
