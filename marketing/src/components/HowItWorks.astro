---
const steps = [
  {
    n: "01",
    title: "Run it",
    body: "One Docker command with a master key. SQLite by default — Postgres when you outgrow it. Boot refuses to start without a key.",
    code: "docker run -p 8080:8080 casualoffice/dochub:latest",
  },
  {
    n: "02",
    title: "Open it",
    body: "Visit hub.your-server. Create the admin account. Create a project. You're in.",
    code: "https://hub.your-server",
  },
  {
    n: "03",
    title: "Keep it",
    body: "Upload a document. Edit it natively. Every save appends an encrypted, hash-chained version — searchable, restorable, provable.",
    code: null,
  },
];
---

<section id="how" class="section cv-auto">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">How it works</p>
      <h2 class="section-title">Three steps. No vendor lock-in.</h2>
      <p class="section-lede">
        You don't need Kubernetes. You don't need a sales call. You need a
        server with port 80 free and a master key you control.
      </p>
    </header>

    <ol class="how-list">
      {
        steps.map((s) => (
          <li class="how-step">
            <span class="how-num" aria-hidden="true">
              {s.n}
            </span>
            <div class="how-body">
              <h3 class="how-title">{s.title}</h3>
              <p class="how-desc">{s.body}</p>
              {s.code && (
                <pre class="how-code"><code>{s.code}</code></pre>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .how-list {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }

  .how-step {
    position: relative;
    padding: var(--space-6);
    background: var(--card);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .how-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    font-family: var(--font-mono);
    font-size: var(--text-md);
    color: var(--on-violet);
    background: var(--violet-500);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-md);
    letter-spacing: 0;
    font-weight: 700;
  }

  .how-title {
    font-size: var(--text-xl);
    letter-spacing: -0.015em;
    font-weight: 650;
  }

  .how-desc {
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .how-code {
    margin-top: auto;
    padding: var(--space-3) var(--space-4);
    background: var(--paper-2);
    border: var(--border-w) solid var(--border);
    box-shadow: var(--shadow-soft);
    color: var(--ink);
    font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>
