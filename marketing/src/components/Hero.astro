---
/**
 * Landing hero. Single H1 on the page. Two CTAs: primary (Demo),
 * secondary (Self-host). Mobile-first: stacked, full-width buttons;
 * desktop: side-by-side. Neobrutalist: big bold display headline, a
 * bordered "browser" frame around the flagship screenshot with a hard
 * offset shadow, a violet primary CTA, and a couple of playful accent
 * glyphs.
 */
import Star from "./icons/Star.astro";
import ArrowRight from "./icons/ArrowRight.astro";
import Box from "./icons/Box.astro";
import Cpu from "./icons/Cpu.astro";
---

<section class="hero">
  <div class="container hero-inner">
    <p class="hero-eyebrow">Casual Office · Doc-Hub</p>
    <h1 class="hero-h1">
      Documents you can trust.
      <span class="hero-h1-accent">
        History you can prove.
        <svg class="hero-spark hero-spark-1" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 6.6L21 12l-6.8 2.2L12 21l-2.2-6.8L3 12l6.8-3.4z"/></svg>
      </span>
    </h1>
    <p class="hero-lede">
      Doc-Hub is an open-source, self-hosted document <strong>registry</strong> —
      not a folder. Every <code>.docx</code>, <code>.xlsx</code> and
      <code>.pdf</code> is encrypted at rest, versioned forever in a
      tamper-evident hash chain, edited natively in your browser, and searchable
      by its contents — on your own server.
    </p>

    <div class="hero-ctas">
      <a href="/demo" class="btn btn-primary btn-lg">
        Try the demo
        <ArrowRight size={16} />
      </a>
      <a href="/docs/install" class="btn btn-secondary btn-lg">
        Self-host in 30 seconds
      </a>
    </div>

    <ul class="hero-bullets" role="list">
      <li><Star size={14} /> Apache-2.0 licensed</li>
      <li><Cpu size={14} /> Encrypted at rest &amp; in transit</li>
      <li><Box size={14} /> Single binary · Docker-ready</li>
    </ul>

    <div class="hero-shot-wrap">
      <svg class="hero-spark hero-spark-2" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.2 6.6L21 12l-6.8 2.2L12 21l-2.2-6.8L3 12l6.8-3.4z"/></svg>
      <figure class="hero-shot">
        <div class="hero-shot-bar" aria-hidden="true">
          <span class="hero-dot"></span>
          <span class="hero-dot"></span>
          <span class="hero-dot"></span>
          <span class="hero-shot-url">hub.your-server</span>
        </div>
        <div class="hero-shot-stage">
          <picture>
            <source type="image/avif" srcset="/screenshots/files-list.avif" />
            <source type="image/webp" srcset="/screenshots/files-list.webp" />
            <img
              src="/screenshots/files-list.png"
              alt="Doc-Hub file list — folders and versioned documents: an .xlsx, a .docx, and a PDF"
              width="1600"
              height="1000"
              loading="eager"
              decoding="sync"
              fetchpriority="high"
            />
          </picture>
        </div>
      </figure>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: var(--space-16) var(--space-12);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: var(--space-20) var(--space-16);
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink);
    background: var(--violet-100);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    margin-bottom: var(--space-6);
  }

  .hero-h1 {
    font-size: var(--text-5xl);
    line-height: 1.03;
    letter-spacing: -0.035em;
    margin-bottom: var(--space-5);
    font-weight: 700;
  }

  @media (min-width: 1024px) {
    .hero-h1 {
      font-size: var(--text-6xl);
    }
  }

  .hero-h1-accent {
    position: relative;
    color: var(--violet-500);
    white-space: nowrap;
  }

  .hero-spark {
    position: absolute;
    width: 0.5em;
    height: 0.5em;
    fill: var(--violet-500);
    pointer-events: none;
  }

  .hero-spark-1 {
    top: -0.15em;
    right: -0.55em;
  }

  .hero-spark-2 {
    top: -14px;
    left: -10px;
    width: 34px;
    height: 34px;
    fill: var(--violet-500);
    z-index: 2;
  }

  .hero-lede {
    font-size: var(--text-lg);
    color: var(--muted);
    line-height: 1.55;
    max-width: 600px;
    margin: 0 auto var(--space-8);
  }

  @media (min-width: 768px) {
    .hero-lede {
      font-size: var(--text-xl);
    }
  }

  .hero-lede :global(code) {
    font-size: 0.82em;
  }

  .hero-lede :global(strong) {
    color: var(--ink);
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: stretch;
    max-width: 420px;
    margin: 0 auto var(--space-6);
  }

  @media (min-width: 640px) {
    .hero-ctas {
      flex-direction: row;
      max-width: none;
      justify-content: center;
    }
  }

  .hero-bullets {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-5);
    padding: 0;
    margin: 0 0 var(--space-12);
    list-style: none;
    font-size: var(--text-sm);
    font-weight: 550;
    color: var(--ink-soft);
  }

  .hero-bullets li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
  }

  /* ── Bordered "browser" device frame with a hard offset shadow ────── */
  .hero-shot-wrap {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
  }

  .hero-shot {
    position: relative;
    margin: 0;
    background: var(--card);
    border: var(--border-w) solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-hover);
    overflow: hidden;
  }

  .hero-shot-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--paper-2);
    border-bottom: var(--border-w) solid var(--border);
  }

  .hero-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: var(--border-w) solid var(--border);
    background: var(--card);
  }

  .hero-dot:nth-child(1) {
    background: var(--danger);
  }
  .hero-dot:nth-child(2) {
    background: var(--warn);
  }
  .hero-dot:nth-child(3) {
    background: var(--success);
  }

  .hero-shot-url {
    margin-left: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-soft);
  }

  .hero-shot-stage {
    aspect-ratio: 16 / 10;
    background: var(--bg-subtle);
  }

  .hero-shot-stage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
</style>
